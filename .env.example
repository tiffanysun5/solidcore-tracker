# Copy this to .env and fill in your values.
# NEVER commit .env to git.

# ── Wellhub credentials ───────────────────────────────────────────────────
WELLHUB_EMAIL=alex.conrad@ashlercapital.com
WELLHUB_PASSWORD=<your_password>

# ── Gmail SMTP (for email digests) ────────────────────────────────────────
# Use a Gmail App Password, NOT your main Gmail password.
# Generate one at: https://myaccount.google.com/apppasswords
# Set App name = "Solidcore Tracker", Category = Mail
SMTP_USER=<your_gmail_address>@gmail.com
SMTP_PASSWORD=<16_char_app_password>

# ── GitHub repo (enables one-click booking link in email) ─────────────────
# Format: "username/repo-name"
GITHUB_REPO=tiffanysun/solidcore-tracker

# ── Cloudflare Worker (per-class Book buttons in email) ───────────────────
# After deploying the worker, paste its URL here:
BOOKING_WORKER_URL=https://solidcore-booking.<your-subdomain>.workers.dev
# Random secret shared between the worker and email links (make up any string):
BOOKING_SECRET=<random_string_you_invent>
